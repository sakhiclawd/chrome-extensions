{
  "manifest_version": 3,
  "name": "Competitor Analyzer",
  "version": "1.0.1",
  "description": "Quickly understand competitor traffic and SEO metrics for any website.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://www.pmdirectory.net/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.svg",
      "48": "icons/icon.svg",
      "128": "icons/icon.svg"
    }
  },
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
