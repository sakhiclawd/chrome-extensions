{
  "manifest_version": 3,
  "name": "AI Webpage Summary",
  "version": "1.0",
  "description": "Get quick AI summaries of long content with one click.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}