{
  "manifest_version": 3,
  "name": "Briefly AI",
  "version": "1.1",
  "description": "High-signal AI summaries for product leaders.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}