{
  "manifest_version": 3,
  "name": "Focus Mode & Site Blocker",
  "version": "1.0.0",
  "description": "Block distracting websites during your focus sessions.",
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "alarms"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "host_permissions": [
    "<all_urls>"
  ]
}
